{
  "permissions": {
    "allow": [
      "PowerShell(node --version)",
      "PowerShell(npm --version)",
      "PowerShell($env:AUTH_SECRET='build-check'; $env:DATABASE_URL='postgresql://x:x@localhost:5432/x'; npm run build 2>&1 | Select-Object -Last 50)",
      "PowerShell(npm run *)",
      "PowerShell(npx eslint components/landing/landing-page.tsx app/page.tsx)",
      "PowerShell(npx next build)",
      "PowerShell(npx prisma db push)",
      "PowerShell(npm install *)",
      "PowerShell(npx playwright install chromium)",
      "PowerShell(npx playwright test)",
      "PowerShell(Get-NetTCPConnection *)"
    ]
  }
}
