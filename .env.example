# ── App ──────────────────────────────────────────────────────────────
# Public URL of the app (used for invitation links, CORS, socket origin)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL) ────────────────────────────────────────────
# Local dev: matches docker-compose.yml
# Production: managed Postgres (e.g. Render PostgreSQL) connection string
DATABASE_URL=postgresql://collabspace:collabspace@localhost:5432/collabspace?schema=public

# ── Redis ────────────────────────────────────────────────────────────
# Local dev: matches docker-compose.yml
# Production: managed Redis (e.g. Render Key Value) connection string
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Avatars and task attachments are stored directly in PostgreSQL (no S3/AWS).
