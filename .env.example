# ── App ──────────────────────────────────────────────────────────────
# Public URL of the app (used for invitation links, CORS, socket origin)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL) ────────────────────────────────────────────
# Local dev: matches docker-compose.yml
# Production: Amazon RDS endpoint, injected via AWS Secrets Manager
DATABASE_URL=postgresql://collabspace:collabspace@localhost:5432/collabspace?schema=public

# ── Redis ────────────────────────────────────────────────────────────
# Local dev: matches docker-compose.yml
# Production: Amazon ElastiCache endpoint, injected via AWS Secrets Manager
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=Fazeelk@2004@03376114144@03009630723

# ── AWS S3 (file uploads) ────────────────────────────────────────────
# In production on ECS, prefer the task IAM role; keys are only for local dev.
AWS_REGION=us-east-1
S3_BUCKET_NAME=collabspace-attachments
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Set to "1" to disable S3 and store nothing (attachments disabled locally)
S3_DISABLED=0
